PORT=5000
NODE_ENV=development

# MongoDB Atlas Connection String
# Get this from: MongoDB Atlas Dashboard > Connect > Connect your application
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority

# JWT Secret Key
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-here

# Email Configuration for Security Features (Login Alerts, 2FA, etc.)
# For Gmail:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Use the generated 16-character password below (remove spaces)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# Tripadvisor RapidAPI (for live restaurant recommendations)
TRIPADVISOR_RAPIDAPI_KEY=your-rapidapi-key-here
TRIPADVISOR_RAPIDAPI_HOST=tripadvisor16.p.rapidapi.com

